        <mxCell id="gwsRCMPZvzJqKpjvKFgN-50" value="1. 行胜于言&lt;br&gt;2. 分解结构&lt;br&gt;3. 量化&lt;br&gt;4. 列清单&lt;br&gt;5. 取舍" style="whiteSpace=wrap;html=1;" parent="gwsRCMPZvzJqKpjvKFgN-1" vertex="1">
