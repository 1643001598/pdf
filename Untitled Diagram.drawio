        <mxCell id="8xf_I44w6tOWVB2IlzFr-36" value="隔离手机" style="whiteSpace=wrap;html=1;fontColor=#1D3557;fillColor=#A8DADC;strokeColor=#457B9D;" parent="2H0J43z-4yzuzr3_J6yP-1" vertex="1">
